# DPO Training - Ultra Low Memory Configuration (极限优化)
# 如果标准配置仍然 OOM，使用这个配置

# ============ 极限显存优化 ============
# 1. 更短的序列长度
QLORA_MAX_SEQ_LEN=384

# 2. 最小 LoRA rank
QLORA_LORA_R=4
QLORA_LORA_ALPHA=8
QLORA_LORA_DROPOUT=0.05

# 3. 减少 LoRA target modules (只训练 attention)
QLORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# 4. 最小配对数
QLORA_DPO_MAX_PAIRS=2

# 5. 更小的 prompt/target 长度
QLORA_DPO_MAX_PROMPT_LENGTH=256
QLORA_DPO_MAX_TARGET_LENGTH=8

# 6. 更大的梯度累积来补偿小 batch
QLORA_BATCH_SIZE=1
QLORA_GRAD_ACC=32

# ============ DPO 参数 ============
QLORA_DPO_BETA=0.1
QLORA_DPO_LOSS_TYPE=sigmoid
QLORA_DPO_PREFER_EASY_NEG=true
QLORA_DPO_FILTER_INVERTED=false
QLORA_DPO_STRIP_RANK_FEATURES=false

# ============ 训练参数 ============
QLORA_EPOCHS=1.0
QLORA_LR=5e-5
QLORA_WEIGHT_DECAY=0.01
QLORA_WARMUP_RATIO=0.05

# ============ 量化和精度 ============
QLORA_USE_4BIT=true
QLORA_USE_BF16=true
QLORA_GRADIENT_CHECKPOINTING=true

# ============ 其他 ============
QLORA_LOGGING_STEPS=5
QLORA_EVAL_STEPS=500
QLORA_SAVE_STEPS=500
QLORA_RANDOM_SEED=42
BUCKETS_OVERRIDE=10

# ============ 模型 ============
QLORA_BASE_MODEL=Qwen/Qwen3-4B
QLORA_TRUST_REMOTE_CODE=true
QLORA_ENFORCE_REQUIRED_BASE_MODEL=false
