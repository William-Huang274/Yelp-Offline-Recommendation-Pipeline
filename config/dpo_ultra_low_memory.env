# DPO Training - Ultra Low Memory Configuration
# Use this only when the standard profile still OOMs

# ============ Extreme memory controls ============
# 1. Shorter sequence length
QLORA_MAX_SEQ_LEN=384

# 2. Minimum practical LoRA rank
QLORA_LORA_R=4
QLORA_LORA_ALPHA=8
QLORA_LORA_DROPOUT=0.05

# 3. Fewer LoRA target modules (attention only)
QLORA_TARGET_MODULES=q_proj,k_proj,v_proj,o_proj

# 4. Minimum pair count
QLORA_DPO_MAX_PAIRS=2

# 5. Smaller prompt and target lengths
QLORA_DPO_MAX_PROMPT_LENGTH=256
QLORA_DPO_MAX_TARGET_LENGTH=8

# 6. Larger gradient accumulation to offset the small batch size
QLORA_BATCH_SIZE=1
QLORA_GRAD_ACC=32

# ============ DPO parameters ============
QLORA_DPO_BETA=0.1
QLORA_DPO_LOSS_TYPE=sigmoid
QLORA_DPO_PREFER_EASY_NEG=true
QLORA_DPO_FILTER_INVERTED=false
QLORA_DPO_STRIP_RANK_FEATURES=false

# ============ Training parameters ============
QLORA_EPOCHS=1.0
QLORA_LR=5e-5
QLORA_WEIGHT_DECAY=0.01
QLORA_WARMUP_RATIO=0.05

# ============ Quantization and precision ============
QLORA_USE_4BIT=true
QLORA_USE_BF16=true
QLORA_GRADIENT_CHECKPOINTING=true

# ============ Other ============
QLORA_LOGGING_STEPS=5
QLORA_EVAL_STEPS=500
QLORA_SAVE_STEPS=500
QLORA_RANDOM_SEED=42
BUCKETS_OVERRIDE=10

# ============ Model ============
QLORA_BASE_MODEL=Qwen/Qwen3-4B
QLORA_TRUST_REMOTE_CODE=true
QLORA_ENFORCE_REQUIRED_BASE_MODEL=false
