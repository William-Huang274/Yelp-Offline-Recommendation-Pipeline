# DPO Training - Low Memory Configuration for 4060 Laptop (8GB VRAM)
# 针对 8GB 显存优化的 pairwise DPO 配置

# ============ 核心显存优化 ============
# 1. 减小序列长度 (最大影响)
QLORA_MAX_SEQ_LEN=512

# 2. 减小 LoRA rank (降低参数量)
QLORA_LORA_R=8
QLORA_LORA_ALPHA=16

# 3. 最小 batch size + 更大的梯度累积
QLORA_BATCH_SIZE=1
QLORA_GRAD_ACC=16

# 4. 减少每用户配对数量 (减少数据集大小)
QLORA_DPO_MAX_PAIRS=4

# 5. 减小 prompt 和 target 长度
QLORA_DPO_MAX_PROMPT_LENGTH=384
QLORA_DPO_MAX_TARGET_LENGTH=8

# ============ DPO 参数 ============
QLORA_DPO_BETA=0.1
QLORA_DPO_LOSS_TYPE=sigmoid
QLORA_DPO_PREFER_EASY_NEG=true
QLORA_DPO_FILTER_INVERTED=false

# ============ 训练参数 ============
QLORA_EPOCHS=1.0
QLORA_LR=5e-5
QLORA_WEIGHT_DECAY=0.01
QLORA_WARMUP_RATIO=0.05

# ============ 量化和精度 ============
QLORA_USE_4BIT=true
QLORA_USE_BF16=true
QLORA_GRADIENT_CHECKPOINTING=true

# ============ 其他 ============
QLORA_LOGGING_STEPS=10
QLORA_EVAL_STEPS=500
QLORA_SAVE_STEPS=500
BUCKETS_OVERRIDE=10

# ============ 模型 ============
QLORA_BASE_MODEL=Qwen/Qwen3-4B
QLORA_TRUST_REMOTE_CODE=true
