# DPO Training - Semantic Mode Configuration (推荐)
# 使用 semantic 模式，移除排序特征，减少 prompt 长度

# ============ Prompt 模式 (重要!) ============
# semantic: 移除排序特征，更适合 DPO
# full: 包含所有特征（默认）
QLORA_PROMPT_MODE=semantic

# ============ 核心显存优化 ============
# 使用 semantic 模式后，prompt 会更短，可以用更大的 MAX_SEQ_LEN
QLORA_MAX_SEQ_LEN=640

# 2. LoRA rank
QLORA_LORA_R=8
QLORA_LORA_ALPHA=16

# 3. Batch size + 梯度累积
QLORA_BATCH_SIZE=1
QLORA_GRAD_ACC=16

# 4. 每用户配对数量
QLORA_DPO_MAX_PAIRS=4

# 5. DPO prompt 和 target 长度
QLORA_DPO_MAX_PROMPT_LENGTH=620
QLORA_DPO_MAX_TARGET_LENGTH=16

# ============ DPO 参数 ============
QLORA_DPO_BETA=0.1
QLORA_DPO_LOSS_TYPE=sigmoid
QLORA_DPO_PREFER_EASY_NEG=true
QLORA_DPO_FILTER_INVERTED=false

# ============ 训练参数 ============
QLORA_EPOCHS=1.0
QLORA_LR=5e-5
QLORA_WEIGHT_DECAY=0.01
QLORA_WARMUP_RATIO=0.05

# ============ 量化和精度 ============
QLORA_USE_4BIT=true
QLORA_USE_BF16=true
QLORA_GRADIENT_CHECKPOINTING=true

# ============ 其他 ============
QLORA_LOGGING_STEPS=10
QLORA_EVAL_STEPS=500
QLORA_SAVE_STEPS=500
BUCKETS_OVERRIDE=10

# ============ 模型 ============
QLORA_BASE_MODEL=Qwen/Qwen3-4B
QLORA_TRUST_REMOTE_CODE=true
