# DPO Training - Semantic Mode Configuration (recommended)
# Use semantic mode to remove ranking-heavy features and shorten prompts

# ============ Prompt mode ============
# semantic: removes ranking-heavy features and is usually a cleaner DPO fit
# full: keeps the full prompt with all features
QLORA_PROMPT_MODE=semantic

# ============ Core memory controls ============
# With semantic mode, prompts are shorter and can support a larger MAX_SEQ_LEN
QLORA_MAX_SEQ_LEN=640

# 2. LoRA rank
QLORA_LORA_R=8
QLORA_LORA_ALPHA=16

# 3. Batch size with gradient accumulation
QLORA_BATCH_SIZE=1
QLORA_GRAD_ACC=16

# 4. Pairs per user
QLORA_DPO_MAX_PAIRS=4

# 5. DPO prompt and target lengths
QLORA_DPO_MAX_PROMPT_LENGTH=620
QLORA_DPO_MAX_TARGET_LENGTH=16

# ============ DPO parameters ============
QLORA_DPO_BETA=0.1
QLORA_DPO_LOSS_TYPE=sigmoid
QLORA_DPO_PREFER_EASY_NEG=true
QLORA_DPO_FILTER_INVERTED=false

# ============ Training parameters ============
QLORA_EPOCHS=1.0
QLORA_LR=5e-5
QLORA_WEIGHT_DECAY=0.01
QLORA_WARMUP_RATIO=0.05

# ============ Quantization and precision ============
QLORA_USE_4BIT=true
QLORA_USE_BF16=true
QLORA_GRADIENT_CHECKPOINTING=true

# ============ Other ============
QLORA_LOGGING_STEPS=10
QLORA_EVAL_STEPS=500
QLORA_SAVE_STEPS=500
BUCKETS_OVERRIDE=10

# ============ Model ============
QLORA_BASE_MODEL=Qwen/Qwen3-4B
QLORA_TRUST_REMOTE_CODE=true
